+
+__attribute__((no_sanitize_address))
+static inline int hyp_pct_cpu_id_write_freq_request(uint8_t cpu_id, uint64_t value)
+{
+	register uint64_t r0 asm("x0") = HVC_NR_CPU_FREQ;
