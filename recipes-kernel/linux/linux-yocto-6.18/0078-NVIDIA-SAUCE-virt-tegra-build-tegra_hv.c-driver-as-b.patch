+__attribute__((no_sanitize_address))
+static inline int hyp_read_gid(unsigned int *gid)
+{
+	register uint64_t r0 asm("x0");
+	register uint64_t r1 asm("x1");
+
+	asm("hvc %2"
+		: "=r"(r0), "=r"(r1)
+		: "i"(HVC_NR_READ_GID)
+		: "x2", "x3", _X4_X17);
+
+	*gid = r1;
+	return (int)r0;
+}
