From 35c8ed2e42187a4ca68453b2a5a6950b955d15e8 Mon Sep 17 00:00:00 2001
From: Sing-Han Chen <singhanc@nvidia.com>
Date: Tue, 18 Jun 2024 06:59:42 +0000
Subject: [PATCH 46/95] NVIDIA: SAUCE: usb: xhci: skip mbox configuration

This change skips the mbox configuration for the
project that doesn't need this.

http://nvbugs/4703456

Upstream-Status: Backport
Signed-off-by: Sing-Han Chen <singhanc@nvidia.com>
Signed-off-by: Bodla Rakesh Babu <rbodla@nvidia.com>
Signed-off-by: Laxman Dewangan <ldewangan@nvidia.com>
Acked-by: Noah Wager <noah.wager@canonical.com>
Acked-by: Jacob Martin <jacob.martin@canonical.com>
Signed-off-by: Noah Wager <noah.wager@canonical.com>
(cherry picked from commit d202f0cf68968a7c8ea3150058935790ab58acdd)
Signed-off-by: Matt Madison <matt@madison.systems>
---
 drivers/usb/host/xhci-tegra.c | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/drivers/usb/host/xhci-tegra.c b/drivers/usb/host/xhci-tegra.c
index 2df32f9ae2c4..eca44185f1a7 100644
--- a/drivers/usb/host/xhci-tegra.c
+++ b/drivers/usb/host/xhci-tegra.c
@@ -246,6 +246,7 @@ struct tegra_xusb_soc {
 	bool scale_ss_clock;
 	bool has_ipfs;
 	bool lpm_support;
+	bool skip_mbox_config;
 	bool otg_reset_sspi;
 
 	bool has_bar2;
@@ -1253,6 +1254,9 @@ static int __tegra_xusb_enable_firmware_messages(struct tegra_xusb *tegra)
 	struct tegra_xusb_mbox_msg msg;
 	int err;
 
+	if (tegra->soc->skip_mbox_config)
+		return 0;
+
 	/* Enable firmware messages from controller. */
 	msg.cmd = MBOX_CMD_MSG_ENABLED;
 	msg.data = 0;
@@ -2767,6 +2771,7 @@ static const struct tegra_xusb_soc tegra264_soc = {
 		.owner = XUSB_BAR2_ARU_MBOX_OWNER,
 		.smi_intr = XUSB_BAR2_ARU_SMI_INTR,
 	},
+	.skip_mbox_config = true,
 	.lpm_support = true,
 	.has_bar2 = true,
 };
-- 
