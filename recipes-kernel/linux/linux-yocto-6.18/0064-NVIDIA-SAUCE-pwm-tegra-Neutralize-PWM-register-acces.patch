From 90383315da817fbc620dd29648d51923cfa308a2 Mon Sep 17 00:00:00 2001
From: Yi-Wei Wang <yiweiw@nvidia.com>
Date: Mon, 15 Jul 2024 23:29:04 +0800
Subject: [PATCH 64/95] NVIDIA: SAUCE: pwm: tegra: Neutralize PWM register
 access helpers

Tegra210 or earlier chips have only one PWM controller, which supports
multiple channels, with the offset of 0x10 between each channel.
To take care of the offset between each channel, left shift by 4 was
implemented in pwm_readl() and pwm_writel(), which resulted in not every
register in the range being accessible through the pwm_readl() and
pwm_writel() helpers.

Later chips have multiple PWM controller instances, each supporting a
single channel. Therefore, the per-chip relative index of the PWM device
hwpwm is always zero and is not affected by left shifts.

To make every register in the range accessible, channel offset is
introduced inside the tegra_pwm_soc structure to neutralize the pwm
register access helpers.

http://nvbugs/4748816

Upstream-Status: Backport
Signed-off-by: Yi-Wei Wang <yiweiw@nvidia.com>
Signed-off-by: Laxman Dewangan <ldewangan@nvidia.com>
Acked-by: Noah Wager <noah.wager@canonical.com>
Acked-by: Jacob Martin <jacob.martin@canonical.com>
Signed-off-by: Noah Wager <noah.wager@canonical.com>
(cherry picked from commit 3f7c61e783259f7fd42a4d05eaf090cc13d47a1e)
Signed-off-by: Matt Madison <matt@madison.systems>
---
 drivers/pwm/pwm-tegra.c | 22 +++++++++++++++-------
 1 file changed, 15 insertions(+), 7 deletions(-)

diff --git a/drivers/pwm/pwm-tegra.c b/drivers/pwm/pwm-tegra.c
index 608ed6b56368..fd73f7a044b8 100644
--- a/drivers/pwm/pwm-tegra.c
+++ b/drivers/pwm/pwm-tegra.c
@@ -58,6 +58,7 @@
 #define PWM_SCALE_SHIFT	0
 
 struct tegra_pwm_soc {
+	unsigned int channel_offset;
 	unsigned int num_channels;
 };
 
@@ -80,12 +81,12 @@ static inline struct tegra_pwm_chip *to_tegra_pwm_chip(struct pwm_chip *chip)
 
 static inline u32 pwm_readl(struct tegra_pwm_chip *pc, unsigned int offset)
 {
-	return readl(pc->regs + (offset << 4));
+	return readl(pc->regs + offset);
 }
 
 static inline void pwm_writel(struct tegra_pwm_chip *pc, unsigned int offset, u32 value)
 {
-	writel(value, pc->regs + (offset << 4));
+	writel(value, pc->regs + offset);
 }
 
 static int tegra_pwm_config(struct pwm_chip *chip, struct pwm_device *pwm,
@@ -194,7 +195,7 @@ static int tegra_pwm_config(struct pwm_chip *chip, struct pwm_device *pwm,
 	} else
 		val |= PWM_ENABLE;
 
-	pwm_writel(pc, pwm->hwpwm, val);
+	pwm_writel(pc, pwm->hwpwm * pc->soc->channel_offset, val);
 
 	/*
 	 * If the PWM is not enabled, turn the clock off again to save power.
@@ -208,6 +209,7 @@ static int tegra_pwm_config(struct pwm_chip *chip, struct pwm_device *pwm,
 static int tegra_pwm_enable(struct pwm_chip *chip, struct pwm_device *pwm)
 {
 	struct tegra_pwm_chip *pc = to_tegra_pwm_chip(chip);
+	unsigned int enb_offset;
 	int rc = 0;
 	u32 val;
 
@@ -215,9 +217,10 @@ static int tegra_pwm_enable(struct pwm_chip *chip, struct pwm_device *pwm)
 	if (rc)
 		return rc;
 
-	val = pwm_readl(pc, pwm->hwpwm);
+	enb_offset = pwm->hwpwm * pc->soc->channel_offset;
+	val = pwm_readl(pc, enb_offset);
 	val |= PWM_ENABLE;
-	pwm_writel(pc, pwm->hwpwm, val);
+	pwm_writel(pc, enb_offset, val);
 
 	return 0;
 }
@@ -225,11 +228,13 @@ static int tegra_pwm_enable(struct pwm_chip *chip, struct pwm_device *pwm)
 static void tegra_pwm_disable(struct pwm_chip *chip, struct pwm_device *pwm)
 {
 	struct tegra_pwm_chip *pc = to_tegra_pwm_chip(chip);
+	unsigned int enb_offset;
 	u32 val;
 
-	val = pwm_readl(pc, pwm->hwpwm);
+	enb_offset = pwm->hwpwm * pc->soc->channel_offset;
+	val = pwm_readl(pc, enb_offset);
 	val &= ~PWM_ENABLE;
-	pwm_writel(pc, pwm->hwpwm, val);
+	pwm_writel(pc, enb_offset, val);
 
 	pm_runtime_put_sync(pwmchip_parent(chip));
 }
@@ -393,14 +398,17 @@ static int __maybe_unused tegra_pwm_runtime_resume(struct device *dev)
 }
 
 static const struct tegra_pwm_soc tegra20_pwm_soc = {
+	.channel_offset = 16,
 	.num_channels = 4,
 };
 
 static const struct tegra_pwm_soc tegra186_pwm_soc = {
+	.channel_offset = 0,
 	.num_channels = 1,
 };
 
 static const struct tegra_pwm_soc tegra194_pwm_soc = {
+	.channel_offset = 0,
 	.num_channels = 1,
 };
 
