 static const struct tegra_hte_data t194_aon_hte = {
 	.map_sz = ARRAY_SIZE(tegra194_aon_gpio_map),
 	.map = tegra194_aon_gpio_map,
@@ -335,6 +423,15 @@ static const struct tegra_hte_data t234_aon_hte = {
 	.slices = 3,
 };
 
