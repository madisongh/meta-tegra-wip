 	.channel_reg_size = SZ_64K,
 	.max_dma_count = SZ_1G,
 	.hw_support_pause = true,
@@ -1389,6 +1407,7 @@ static const struct tegra_dma_chip_data tegra194_dma_chip_data = {
 
