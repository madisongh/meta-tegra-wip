---
 drivers/phy/tegra/xusb-tegra186.c | 4 ----
 1 file changed, 4 deletions(-)

diff --git a/drivers/phy/tegra/xusb-tegra186.c b/drivers/phy/tegra/xusb-tegra186.c
index 739649c14d4c..be9b971526c3 100644
--- a/drivers/phy/tegra/xusb-tegra186.c
+++ b/drivers/phy/tegra/xusb-tegra186.c
@@ -986,15 +986,11 @@ static int tegra186_utmi_phy_power_on(struct phy *phy)
 		padctl_writel(padctl, value, XUSB_PADCTL_USB2_OTG_PADX_CTL3(index));
 	}
 
-	tegra186_utmi_pad_power_on(phy);
-
 	return 0;
 }
 
 static int tegra186_utmi_phy_power_off(struct phy *phy)
 {
-	tegra186_utmi_pad_power_down(phy);
-
 	return 0;
 }
 
