From 242f89cf6392335f4186f1542593b487e54f1679 Mon Sep 17 00:00:00 2001
From: Sing-Han Chen <singhanc@nvidia.com>
Date: Wed, 17 Jul 2024 18:41:33 +0000
Subject: [PATCH 49/95] NVIDIA: SAUCE: usb: gadget: xudc: Enable u1/u2 for
 Tegra264

This change enable u1/u2 support for T264

http://nvbugs/4295138
http://nvbugs/4753858

Upstream-Status: Backport
Signed-off-by: Sing-Han Chen <singhanc@nvidia.com>
Signed-off-by: Laxman Dewangan <ldewangan@nvidia.com>
Acked-by: Noah Wager <noah.wager@canonical.com>
Acked-by: Jacob Martin <jacob.martin@canonical.com>
Signed-off-by: Noah Wager <noah.wager@canonical.com>
(cherry picked from commit ec472102096075ceeac3b6798bd9b6cb1a591ec1)
Signed-off-by: Matt Madison <matt@madison.systems>
---
 drivers/usb/gadget/udc/tegra-xudc.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/usb/gadget/udc/tegra-xudc.c b/drivers/usb/gadget/udc/tegra-xudc.c
index a1f2770e5fea..84b39a9cb0c2 100644
--- a/drivers/usb/gadget/udc/tegra-xudc.c
+++ b/drivers/usb/gadget/udc/tegra-xudc.c
@@ -3699,8 +3699,8 @@ static struct tegra_xudc_soc tegra264_xudc_soc_data = {
 	.clock_names = tegra186_xudc_clock_names,
 	.num_clks = ARRAY_SIZE(tegra186_xudc_clock_names),
 	.num_phys = 4,
-	.u1_enable = false,
-	.u2_enable = false,
+	.u1_enable = true,
+	.u2_enable = true,
 	.lpm_enable = true,
 	.invalid_seq_num = false,
 	.pls_quirk = false,
-- 
2.43.0

