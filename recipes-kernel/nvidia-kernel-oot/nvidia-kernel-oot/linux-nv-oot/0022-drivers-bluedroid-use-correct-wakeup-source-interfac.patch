From 28515ce9f311432425c116bae0d73cdd2208cc92 Mon Sep 17 00:00:00 2001
From: Meng Li <Meng.Li@windriver.com>
Date: Mon, 9 Feb 2026 19:50:42 +0800
Subject: [PATCH 22/30] drivers: bluedroid: use correct wakeup source
 interfaces

Based on kernel upstream commit 142ba31d8b4("PM: wakeup: Do
not expose 4 device wakeup source APIs "), it needs to use new
wakeup source interfaces to replace the unexposed ones.

Upstream-Status: Pending

Signed-off-by: Meng Li <Meng.Li@windriver.com>
---
 drivers/misc/bluedroid_pm.c | 29 +++++++++++++++++++++++++++++
 1 file changed, 29 insertions(+)

diff --git a/drivers/misc/bluedroid_pm.c b/drivers/misc/bluedroid_pm.c
index 5283015d..b8b1aeac 100644
--- a/drivers/misc/bluedroid_pm.c
+++ b/drivers/misc/bluedroid_pm.c
@@ -3,6 +3,7 @@
 
 #include <nvidia/conftest.h>
 
+#include <linux/version.h>
 #include <linux/uaccess.h>
 #include <linux/module.h>
 #include <linux/proc_fs.h>
@@ -50,7 +51,11 @@ struct bluedroid_pm_data {
 	struct regulator *vdd_3v3;
 	struct regulator *vdd_1v8;
 	struct rfkill *rfkill;
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+	struct wakeup_source *wake_lock;
+#else
 	struct wakeup_source wake_lock;
+#endif
 	struct pm_qos_request resume_cpu_freq_req;
 	bool resumed;
 	struct work_struct work;
@@ -150,7 +155,11 @@ static void bluedroid_pm_timer_expire(struct timer_list *timer)
 		/* BT can sleep */
 		BDP_DBG("Tx and Rx are idle, BT sleeping");
 		bluedroid_pm_gpio_set_value(bluedroid_pm->ext_wake, 0);
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+	__pm_relax(bluedroid_pm->wake_lock);
+#else
 		__pm_relax(&bluedroid_pm->wake_lock);
+#endif
 	} else {
 		/* BT Rx is busy, Reset Timer */
 		BDP_DBG("Rx is busy, restarting the timer");
@@ -177,7 +186,11 @@ static int bluedroid_pm_rfkill_set_power(void *data, bool blocked)
 		if (bluedroid_pm->vdd_1v8)
 			ret |= regulator_disable(bluedroid_pm->vdd_1v8);
 		if (gpio_is_valid(bluedroid_pm->ext_wake))
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+			__pm_relax(bluedroid_pm->wake_lock);
+#else
 			__pm_relax(&bluedroid_pm->wake_lock);
+#endif
 		if (bluedroid_pm->resume_min_frequency)
 			cpu_latency_qos_remove_request(&bluedroid_pm->resume_cpu_freq_req);
 	} else {
@@ -252,7 +265,11 @@ static ssize_t lpm_write_proc(struct file *file, const char __user *buffer,
 				BDP_DBG("Tx and Rx are idle, BT sleeping");
 					bluedroid_pm_gpio_set_value(
 						bluedroid_pm->ext_wake, 0);
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+					__pm_relax(bluedroid_pm->wake_lock);
+#else
 					__pm_relax(&bluedroid_pm->wake_lock);
+#endif
 				} else {
 					/* Reset Timer */
 					BDP_DBG("Rx is busy, restarting the timer");
@@ -264,7 +281,11 @@ static ssize_t lpm_write_proc(struct file *file, const char __user *buffer,
 			BDP_DBG("Tx is busy, wake_lock taken, delete timer");
 			bluedroid_pm_gpio_set_value(
 				bluedroid_pm->ext_wake, 1);
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+			__pm_stay_awake(bluedroid_pm->wake_lock);
+#else
 			__pm_stay_awake(&bluedroid_pm->wake_lock);
+#endif
 #if defined(NV_TIMER_DELETE_PRESENT) /* Linux v6.15 */
 			timer_delete(&bluedroid_pm_timer);
 #else
@@ -480,7 +501,11 @@ static int bluedroid_pm_probe(struct platform_device *pdev)
 			goto free_ext_wake;
 		}
 		/* initialize wake lock */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+		bluedroid_pm->wake_lock = wakeup_source_register(&pdev->dev, "bluedroid_pm_wake_lock");
+#else
 		wakeup_source_add(&bluedroid_pm->wake_lock);
+#endif
 		/* Initialize timer */
 		timer_setup(&bluedroid_pm->bluedroid_pm_timer,
 				bluedroid_pm_timer_expire, 0);
@@ -538,7 +563,11 @@ static int bluedroid_pm_remove(struct platform_device *pdev)
 	if (gpio_is_valid(bluedroid_pm->host_wake))
 		gpio_free(bluedroid_pm->host_wake);
 	if (gpio_is_valid(bluedroid_pm->ext_wake)) {
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+		wakeup_source_unregister(bluedroid_pm->wake_lock);
+#else
 		wakeup_source_destroy(&bluedroid_pm->wake_lock);
+#endif
 		gpio_free(bluedroid_pm->ext_wake);
 		remove_bt_proc_interface();
 #if defined(NV_TIMER_DELETE_PRESENT) /* Linux v6.15 */
-- 
2.34.1

