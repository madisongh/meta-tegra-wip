From 928c906c1b3adf7606468507246f78944191247a Mon Sep 17 00:00:00 2001
From: Meng Li <Meng.Li@windriver.com>
Date: Tue, 3 Feb 2026 16:22:47 +0800
Subject: [PATCH 07/30] drivers: tegra: replace devm_gpio_request() with
 devm_gpio_request_one()

Based on kernel upstream commit a55893133830("gpiolib: Remove
unused devm_gpio_request()"), it needs to replace devm_gpio_request()
with devm_gpio_request_one().

Upstream-Status: Pending

Signed-off-by: Meng Li <Meng.Li@windriver.com>
---
 drivers/platform/tegra/tegra-uss-io-proxy.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/platform/tegra/tegra-uss-io-proxy.c b/drivers/platform/tegra/tegra-uss-io-proxy.c
index c4d4f343..6819d21f 100644
--- a/drivers/platform/tegra/tegra-uss-io-proxy.c
+++ b/drivers/platform/tegra/tegra-uss-io-proxy.c
@@ -353,7 +353,7 @@ static int tegra_uss_request_gpio(struct platform_device *pdev, const char *name
 		return -EINVAL;
 	}
 
-	rc = devm_gpio_request(&pdev->dev, gpio, name);
+	rc = devm_gpio_request_one(&pdev->dev, gpio, GPIOF_OUT_INIT_LOW, name);
 	if (rc) {
 		dev_err(&pdev->dev, "could not request %s %d\n", name, rc);
 		return rc;
-- 
